# SAS Converter - Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# LLM PROVIDER CONFIGURATION
# =============================================================================
# Primary provider: azure (default), groq, or ollama
LLM_PROVIDER=azure

# =============================================================================
# AZURE OPENAI (PRIMARY)
# =============================================================================
AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_DEPLOYMENT_MINI=gpt-4o-mini
AZURE_OPENAI_DEPLOYMENT_FULL=gpt-4o

# =============================================================================
# GROQ (FALLBACK)
# =============================================================================
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# =============================================================================
# OLLAMA (LOCAL / OFFLINE)
# =============================================================================
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# =============================================================================
# REDIS (CHECKPOINTING)
# =============================================================================
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# AZURE APPLICATION INSIGHTS (OPTIONAL)
# =============================================================================
# APPINSIGHTS_CONNECTION_STRING=InstrumentationKey=...;IngestionEndpoint=...

# =============================================================================
# DATABASE PATHS (OPTIONAL - DEFAULTS USED IF NOT SET)
# =============================================================================
# DUCKDB_PATH=analytics.duckdb
# LANCEDB_PATH=lancedb_data
# SQLITE_PATH=sas_metadata.db
