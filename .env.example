# ── Codara environment variables ─────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Lines starting with # are comments. All values are optional unless marked REQUIRED.

# ── Primary LLM: Ollama (Nemotron) ───────────────────────────────────────────
OLLAMA_API_KEY=                                 # REQUIRED — Ollama API key
OLLAMA_BASE_URL=http://localhost:11434/v1       # Ollama endpoint
OLLAMA_MODEL=nemotron-3-super:cloud             # Primary model

# ── Fallback 1: Azure OpenAI ──────────────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=                          # e.g. https://yourname.openai.azure.com/
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_DEPLOYMENT_FULL=gpt-4o
AZURE_OPENAI_DEPLOYMENT_MINI=gpt-4o-mini

# ── Fallback 2 + Cross-verifier: Groq ─────────────────────────────────────────
GROQ_API_KEY=                                   # REQUIRED
GROQ_API_KEY_2=                                 # Optional — key rotation on 429
GROQ_API_KEY_3=                                 # Optional — key rotation on 429

# ── Auth ──────────────────────────────────────────────────────────────────────
CODARA_JWT_SECRET=                              # REQUIRED — 256-bit hex, e.g. openssl rand -hex 32
CODARA_ADMIN_PASSWORD=                          # Seed admin password (random if unset)
CODARA_USER_PASSWORD=                           # Seed user password (random if unset)

# ── GitHub OAuth (optional) ───────────────────────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Datastores ────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
SQLITE_PATH=data/codara_api.db
DUCKDB_PATH=data/analytics.duckdb
LANCEDB_PATH=data/lancedb

# ── Azure Storage (optional — falls back to local disk) ───────────────────────
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=codara-uploads
AZURE_QUEUE_NAME=codara-pipeline-jobs

# ── Observability (optional) ──────────────────────────────────────────────────
APPLICATIONINSIGHTS_CONNECTION_STRING=

# ── CORS (optional — default: localhost 8080/5173) ───────────────────────────
# CORS_ORIGINS=https://app.codara.dev,http://localhost:5173
