# ── Codara .env.example ──────────────────────────────────────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit .env to git — it is listed in .gitignore.

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development                    # development | staging | production
APP_VERSION=3.1.0

# ── JWT (REQUIRED) ────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
CODARA_JWT_SECRET=change-me-in-production

# ── Seed account passwords (first-boot only) ──────────────────────────────────
# If unset, random passwords are printed to stdout on first run.
CODARA_ADMIN_PASSWORD=
CODARA_USER_PASSWORD=

# ── LLM — Ollama / Nemotron (PRIMARY) ────────────────────────────────────────
OLLAMA_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=nemotron-3-super:cloud

# ── LLM — Azure OpenAI (fallback 1) ──────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_DEPLOYMENT_MINI=gpt-5.4-mini
AZURE_OPENAI_DEPLOYMENT_FULL=gpt-5.4-mini

# ── LLM — Groq (fallback 2 + cross-verifier) ─────────────────────────────────
GROQ_API_KEY=
GROQ_API_KEY_2=
GROQ_API_KEY_3=
GROQ_MODEL=llama-3.3-70b-versatile

# ── LLM — Gemini (oracle / judge — optional) ─────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ── LLM — Cerebras (Best-of-N — optional) ────────────────────────────────────
CEREBRAS_API_KEY=
CEREBRAS_MODEL=llama3.1-70b

# ── Local GGUF model (Tier 0 — optional) ─────────────────────────────────────
# Download the fine-tuned GGUF and set this path to enable offline Tier 0.
LOCAL_MODEL_PATH=
LOCAL_MODEL_THREADS=4
LOCAL_MODEL_CTX=4096

# ── Database ──────────────────────────────────────────────────────────────────
# Leave empty to use default SQLite path (backend/data/codara_api.db)
SQLITE_PATH=
# Set to postgresql+asyncpg://... to migrate away from SQLite
DATABASE_URL=

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list; add your production domain here for deployment.
# CORS_ORIGINS=https://app.codara.dev,http://localhost:5173

# ── Azure infrastructure (production / staging) ───────────────────────────────
AZURE_KEYVAULT_URL=
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=codara-uploads
AZURE_QUEUE_NAME=codara-pipeline-jobs
APPLICATIONINSIGHTS_CONNECTION_STRING=

# ── GitHub OAuth (optional) ───────────────────────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Feature flags ─────────────────────────────────────────────────────────────
ENABLE_Z3_VERIFICATION=true
